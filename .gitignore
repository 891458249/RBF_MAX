# =============================================================================
# RBF_MAX .gitignore
# =============================================================================

# Build artifacts ------------------------------------------------------------
build/
build-*/
out/
cmake-build-*/
_deps/

# CMake ----------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
Testing/
compile_commands.json

# IDE ------------------------------------------------------------------------
.vs/
.vscode/
.idea/
*.user
*.suo
*.sln
*.vcxproj*
*.xcodeproj/
*.xcworkspace/

# Compiled objects -----------------------------------------------------------
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exp
*.pdb
*.ilk
*.exe
*.mll        # Maya plugin binary
*.mod

# Python ---------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Logs / Coverage ------------------------------------------------------------
*.log
*.gcov
*.gcda
*.gcno
coverage/
*.profraw

# OS -------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# Local overrides ------------------------------------------------------------
/local.cmake
/CMakeUserPresets.json

# Project-specific -----------------------------------------------------------
.unpacked/
.unpacked_text.txt
.remember/
.claude/

# Reference materials (research inputs, not project source):
#   - 铁拳 8 CEDEC/GDC pptx+pdf — licensing unclear, kept local only
#   - chadvernon cmt/jsRadial — upstream MIT source, reference-only
#   - optimization-prompt docx — internal prompt engineering draft
# Preserved in docs/源文档/ on dev machines; never shipped in repo.
docs/源文档/

# Installer payload (built .mll copied in by installer/package.py;
# not checked in because they are large binary build products)
installer/plug-ins/2022/*.mll
installer/plug-ins/2025/*.mll
